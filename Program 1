#include <stdio.h>

void bubbleSort(int a[], int n)
{
    int i, j, temp;
    int count = 0;

    for(i = 0; i <= n-2; i++)
    {
        for(j = 0; j <= n-2-i; j++)
        {
            count++;

            if(a[j] > a[j+1])
            {
                temp = a[j];
                a[j] = a[j+1];
                a[j+1] = temp;
            }
        }
    }

    printf("\nSorted array:\n");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    printf("\nNumber of comparisons = %d\n", count);
}

int main()
{
    int n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int a[n];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    bubbleSort(a, n);

    return 0;
}

#include <stdio.h>

void selectionSort(int a[], int n)
{
    int i, j, min, temp;
    int count = 0;

    for(i = 0; i <= n-2; i++)
    {
        min = i;

        for(j = i+1; j < n; j++)
        {
            count++;

            if(a[j] < a[min])
            {
                min = j;
            }
        }

        if(min != i)
        {
            temp = a[i];
            a[i] = a[min];
            a[min] = temp;
        }
    }

    printf("\nSorted array:\n");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    printf("\nNumber of comparisons = %d\n", count);
}

int main()
{
    int n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int a[n];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    selectionSort(a, n);

    return 0;
}
